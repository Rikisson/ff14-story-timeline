rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Universe creators — keep in sync with src/features/universes/data-access/universe-creators.ts
    function isUniverseCreator() {
      return request.auth != null
        && request.auth.uid in [
          'uDRxrMxHMtNZfgbpNjbJat1BPBE3'
        ];
    }

    function isMember(universeId) {
      let u = get(/databases/$(database)/documents/universes/$(universeId)).data;
      return request.auth != null
        && (u.authorUid == request.auth.uid || request.auth.uid in u.editorUids);
    }

    match /universes/{universeId} {
      // Public read — guests need this to browse and pick a universe.
      allow read: if true;

      allow create: if isUniverseCreator()
        && request.resource.data.authorUid == request.auth.uid;

      allow update: if request.auth != null
        && resource.data.authorUid == request.auth.uid
        && request.resource.data.authorUid == resource.data.authorUid;

      allow delete: if request.auth != null
        && resource.data.authorUid == request.auth.uid;

      match /characters/{characterId} {
        allow read: if true;
        allow create, update, delete: if isMember(universeId);
      }

      match /places/{placeId} {
        allow read: if true;
        allow create, update, delete: if isMember(universeId);
      }

      match /events/{eventId} {
        allow read: if true;
        allow create, update, delete: if isMember(universeId);
      }

      match /stories/{storyId} {
        allow read: if resource.data.draft == false || isMember(universeId);
        allow create, update, delete: if isMember(universeId);

        // Content subdoc: visibility tracks the parent story's draft flag.
        match /_content/{contentDocId} {
          allow read: if get(/databases/$(database)/documents/universes/$(universeId)/stories/$(storyId)).data.draft == false
            || isMember(universeId);
          allow create, update, delete: if isMember(universeId);
        }
      }

      match /plotlines/{plotlineId} {
        allow read: if true;
        allow create, update, delete: if isMember(universeId);
      }

      match /codexEntries/{codexEntryId} {
        allow read: if true;
        allow create, update, delete: if isMember(universeId);
      }

      match /_meta/{docId} {
        allow read: if true;
        allow create, update, delete: if isMember(universeId);
      }

      match /_assets/{assetId} {
        allow read: if true;
        allow create, update, delete: if isMember(universeId);
      }

      // Directory projection — one row per entity across all kinds.
      // Public read is gated per-row by `visiblePublic`; queries must
      // include `where('visiblePublic', '==', true)` for guests, since
      // Firestore rules gate each returned doc rather than auto-filtering.
      match /_directory/{rowId} {
        allow read: if resource.data.visiblePublic == true || isMember(universeId);
        allow create, update, delete: if isMember(universeId);
      }

      // Timeline projections — same shape as the directory rule.
      match /_timelineEntries/{rowId} {
        allow read: if resource.data.visiblePublic == true || isMember(universeId);
        allow create, update, delete: if isMember(universeId);
      }

      match /_timelineLaneEntries/{rowId} {
        allow read: if resource.data.visiblePublic == true || isMember(universeId);
        allow create, update, delete: if isMember(universeId);
      }

      // Slug uniqueness index. Member-only because slug lookups happen
      // by exact doc ID (never by query), so a public read rule would
      // only enable enumeration.
      match /_slugIndex/{rowId} {
        allow read, create, update, delete: if isMember(universeId);
      }
    }
  }
}
