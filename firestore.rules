rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────────────

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid))
           .data.staffRole == 'admin';
    }

    function isMember(universeId) {
      let u = get(/databases/$(database)/documents/universes/$(universeId)).data;
      return request.auth != null
        && (u.authorUid == request.auth.uid || request.auth.uid in u.editorUids);
    }

    function isUniverseActive(universeId) {
      return get(/databases/$(database)/documents/universes/$(universeId))
             .data.deletedAt == null;
    }

    function isPendingCleanup(universeId) {
      return get(/databases/$(database)/documents/universes/$(universeId))
             .data.deletedAt != null;
    }

    function isUnderUniverseCap(uid) {
      let userPath = /databases/$(database)/documents/users/$(uid);
      return !exists(userPath)
        || get(userPath).data.authoredUniverseCount < 2;
    }

    function canCreateUniverse() {
      return request.auth != null
        && (isAdmin() || isUnderUniverseCap(request.auth.uid));
    }

    // ─── users/{uid} ───────────────────────────────────────────────────────────

    match /users/{uid} {
      allow read: if request.auth != null
                  && (request.auth.uid == uid || isAdmin());

      allow create: if request.auth.uid == uid
                    && request.resource.data.keys().hasOnly(['authoredUniverseCount', 'createdAt'])
                    && request.resource.data.authoredUniverseCount == 0;

      allow update: if isAdmin()
                    || (
                      request.auth.uid == uid
                      && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['authoredUniverseCount', 'updatedAt'])
                      && request.resource.data.authoredUniverseCount >= 0
                      && request.resource.data.authoredUniverseCount <= 2
                    );

      allow delete: if isAdmin();
    }

    // ─── universes/{u} ─────────────────────────────────────────────────────────

    match /universes/{universeId} {
      allow read: if resource.data.deletedAt == null
                  || resource.data.authorUid == request.auth.uid
                  || isAdmin();

      allow create: if canCreateUniverse()
                    && request.resource.data.authorUid == request.auth.uid
                    && request.resource.data.deletedAt == null
                    && request.resource.data.storageBytes == 0
                    && request.resource.data.assetCount == 0;

      allow update: if isMember(universeId) && (
                      // Counter writes from the asset upload/delete transaction.
                      (
                        isUniverseActive(universeId)
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['storageBytes', 'assetCount', 'updatedAt'])
                        && request.resource.data.storageBytes is int
                        && request.resource.data.storageBytes >= 0
                        && request.resource.data.storageBytes <= 524288000
                        && request.resource.data.assetCount is int
                        && request.resource.data.assetCount >= 0
                        && request.resource.data.assetCount <= 500
                      )
                      // Metadata edits (slug, name, description, cover, locale).
                      || (
                        isUniverseActive(universeId)
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['slug', 'name', 'description', 'coverAssetId', 'locale', 'updatedAt'])
                      )
                      // Editor roster changes (author or admin only).
                      || (
                        isUniverseActive(universeId)
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['editorUids', 'updatedAt'])
                        && (resource.data.authorUid == request.auth.uid || isAdmin())
                      )
                      // Soft-delete transition (author or admin only).
                      || (
                        resource.data.deletedAt == null
                        && request.resource.data.deletedAt is number
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['deletedAt', 'updatedAt'])
                        && (resource.data.authorUid == request.auth.uid || isAdmin())
                      )
                    );

      // Hard-delete only after soft-delete has marked the universe pending cleanup.
      allow delete: if (resource.data.authorUid == request.auth.uid || isAdmin())
                    && resource.data.deletedAt != null;

      match /characters/{characterId} {
        allow read: if isUniverseActive(universeId) || isMember(universeId) || isAdmin();
        allow create, update: if isMember(universeId)
                              && isUniverseActive(universeId)
                              && (!('sprites' in request.resource.data)
                                  || request.resource.data.sprites.size() <= 32);
        allow delete: if isMember(universeId)
                      && (isUniverseActive(universeId) || isPendingCleanup(universeId));
      }

      match /places/{placeId} {
        allow read: if isUniverseActive(universeId) || isMember(universeId) || isAdmin();
        allow create, update: if isMember(universeId)
                              && isUniverseActive(universeId)
                              && (!('backgrounds' in request.resource.data)
                                  || request.resource.data.backgrounds.size() <= 32)
                              && (!('ambientAudio' in request.resource.data)
                                  || request.resource.data.ambientAudio.size() <= 24);
        allow delete: if isMember(universeId)
                      && (isUniverseActive(universeId) || isPendingCleanup(universeId));
      }

      match /events/{eventId} {
        allow read: if isUniverseActive(universeId) || isMember(universeId) || isAdmin();
        allow create, update: if isMember(universeId) && isUniverseActive(universeId);
        allow delete: if isMember(universeId)
                      && (isUniverseActive(universeId) || isPendingCleanup(universeId));
      }

      match /connections/{connectionId} {
        allow read: if (isUniverseActive(universeId) && resource.data.visibility == 'reader')
                    || isMember(universeId)
                    || isAdmin();
        allow create, update: if isMember(universeId) && isUniverseActive(universeId);
        allow delete: if isMember(universeId)
                      && (isUniverseActive(universeId) || isPendingCleanup(universeId));
      }

      match /stories/{storyId} {
        allow read: if (isUniverseActive(universeId) && resource.data.draft == false)
                    || isMember(universeId)
                    || isAdmin();
        allow create, update: if isMember(universeId) && isUniverseActive(universeId);
        allow delete: if isMember(universeId)
                      && (isUniverseActive(universeId) || isPendingCleanup(universeId));

        match /_content/{contentDocId} {
          allow read: if (isUniverseActive(universeId)
                          && get(/databases/$(database)/documents/universes/$(universeId)/stories/$(storyId)).data.draft == false)
                      || isMember(universeId)
                      || isAdmin();
          allow create, update: if isMember(universeId) && isUniverseActive(universeId);
          allow delete: if isMember(universeId)
                        && (isUniverseActive(universeId) || isPendingCleanup(universeId));
        }
      }

      match /plotlines/{plotlineId} {
        allow read: if isUniverseActive(universeId) || isMember(universeId) || isAdmin();
        allow create, update: if isMember(universeId) && isUniverseActive(universeId);
        allow delete: if isMember(universeId)
                      && (isUniverseActive(universeId) || isPendingCleanup(universeId));
      }

      match /codexEntries/{codexEntryId} {
        allow read: if isUniverseActive(universeId) || isMember(universeId) || isAdmin();
        allow create, update: if isMember(universeId) && isUniverseActive(universeId);
        allow delete: if isMember(universeId)
                      && (isUniverseActive(universeId) || isPendingCleanup(universeId));
      }

      match /_meta/{docId} {
        allow read: if isUniverseActive(universeId) || isMember(universeId) || isAdmin();
        allow create, update: if isMember(universeId) && isUniverseActive(universeId);
        allow delete: if isMember(universeId)
                      && (isUniverseActive(universeId) || isPendingCleanup(universeId));
      }

      match /_assets/{assetId} {
        allow read: if isUniverseActive(universeId) || isMember(universeId) || isAdmin();
        allow create, update: if isMember(universeId) && isUniverseActive(universeId);
        allow delete: if isMember(universeId)
                      && (isUniverseActive(universeId) || isPendingCleanup(universeId));
      }

      match /_directory/{rowId} {
        allow read: if resource.data.visiblePublic == true || isMember(universeId) || isAdmin();
        allow create, update: if isMember(universeId) && isUniverseActive(universeId);
        allow delete: if isMember(universeId)
                      && (isUniverseActive(universeId) || isPendingCleanup(universeId));
      }

      match /_timelineEntries/{rowId} {
        allow read: if resource.data.visiblePublic == true || isMember(universeId) || isAdmin();
        allow create, update: if isMember(universeId) && isUniverseActive(universeId);
        allow delete: if isMember(universeId)
                      && (isUniverseActive(universeId) || isPendingCleanup(universeId));
      }

      // Retired projection — never written anymore; members can still list
      // and delete leftover rows so legacy universes purge fully.
      match /_timelineLaneEntries/{rowId} {
        allow read, delete: if isMember(universeId) || isAdmin();
      }

      // Slug uniqueness index — member-only because lookups happen by exact doc ID
      // (never by query), so a public read rule would only enable enumeration.
      match /_slugIndex/{rowId} {
        allow read: if isMember(universeId) || isAdmin();
        allow create, update: if isMember(universeId) && isUniverseActive(universeId);
        allow delete: if isMember(universeId)
                      && (isUniverseActive(universeId) || isPendingCleanup(universeId));
      }
    }
  }
}
