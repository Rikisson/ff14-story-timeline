{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ff14-story-timeline/migration-kit/universe.schema.json",
  "title": "Universe Import Package",
  "description": "A universe.json import package. Every entity is identified by a slug; entities reference each other by slug, never by id. Omit any field you have no value for.",
  "type": "object",
  "required": ["formatVersion"],
  "properties": {
    "formatVersion": {
      "const": 3,
      "description": "Schema version. Must be 3."
    },
    "generator": {
      "type": "string",
      "description": "Optional free-text note about what produced this file."
    },
    "exportedAt": {
      "type": "number",
      "description": "Optional epoch-millisecond timestamp. Ignored on import."
    },
    "universe": { "$ref": "#/$defs/universe" },
    "calendar": { "$ref": "#/$defs/calendar" },
    "codexCategories": {
      "type": "array",
      "description": "Codex categories. Added to the target universe if their key does not already exist.",
      "items": { "$ref": "#/$defs/codexCategory" }
    },
    "assets": {
      "type": "array",
      "description": "Media metadata. Hand-authored packages normally omit this entirely — leave art fields off your entities and add images in the app after import.",
      "items": { "$ref": "#/$defs/asset" }
    },
    "characters": { "type": "array", "items": { "$ref": "#/$defs/character" } },
    "places": { "type": "array", "items": { "$ref": "#/$defs/place" } },
    "plotlines": { "type": "array", "items": { "$ref": "#/$defs/plotline" } },
    "events": { "type": "array", "items": { "$ref": "#/$defs/event" } },
    "codexEntries": { "type": "array", "items": { "$ref": "#/$defs/codexEntry" } },
    "stories": { "type": "array", "items": { "$ref": "#/$defs/story" } },
    "connections": {
      "type": "array",
      "description": "Typed continuation edges between stories and events. Each ending (a story's end scene, or an event) continues to at most one target.",
      "items": { "$ref": "#/$defs/connection" }
    }
  },
  "$defs": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "maxLength": 60,
      "description": "Lowercase letters, digits, and hyphens. Unique within its kind. Derive it from the name (e.g. 'Lyra Dawnwhisper' -> 'lyra-dawnwhisper') and reuse it verbatim everywhere that entity is referenced."
    },
    "ref": {
      "type": "object",
      "description": "A structured reference to another entity, by slug.",
      "required": ["kind", "ref"],
      "properties": {
        "kind": {
          "enum": ["character", "place", "event", "story", "plotline", "codexEntry"]
        },
        "ref": {
          "allOf": [{ "$ref": "#/$defs/slug" }],
          "description": "The slug of the target entity."
        }
      }
    },
    "inGameDate": {
      "type": "object",
      "description": "An in-world date. Every field is optional; an empty object means the date is unknown.",
      "properties": {
        "era": {
          "type": "string",
          "description": "The slug of an era defined in the calendar."
        },
        "year": { "type": "number" },
        "month": { "type": "number", "description": "1-based index into the calendar's months array." },
        "day": { "type": "number" },
        "hour": { "type": "number" },
        "minute": { "type": "number" },
        "second": { "type": "number" },
        "display": { "type": "string", "description": "Optional author-written override for the displayed date." }
      }
    },
    "universe": {
      "type": "object",
      "description": "Universe metadata. Treated as informational on import — it never renames or replaces the target universe.",
      "required": ["slug", "name", "locale"],
      "properties": {
        "slug": { "$ref": "#/$defs/slug" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "locale": { "enum": ["en", "uk"] },
        "coverAsset": { "type": "string" }
      }
    },
    "calendar": {
      "type": "object",
      "description": "The world calendar. Applied to the target universe only if it has no calendar yet.",
      "required": ["eras", "months"],
      "properties": {
        "eras": { "type": "array", "items": { "$ref": "#/$defs/calendarEra" } },
        "months": { "type": "array", "items": { "$ref": "#/$defs/calendarMonth" } },
        "weekdays": { "type": "array", "items": { "$ref": "#/$defs/calendarWeekday" } }
      }
    },
    "calendarEra": {
      "type": "object",
      "required": ["slug", "name"],
      "properties": {
        "slug": { "$ref": "#/$defs/slug" },
        "name": { "type": "string" },
        "maxYears": { "type": "number" },
        "hoursPerDay": { "type": "number" },
        "minutesPerHour": { "type": "number" },
        "secondsPerMinute": { "type": "number" },
        "resetsWeek": { "type": "boolean" }
      }
    },
    "calendarMonth": {
      "type": "object",
      "required": ["name", "days"],
      "properties": {
        "name": { "type": "string" },
        "days": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "calendarWeekday": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "short": { "type": "string" }
      }
    },
    "codexCategory": {
      "type": "object",
      "required": ["key", "label"],
      "properties": {
        "key": { "$ref": "#/$defs/slug" },
        "label": { "type": "string" },
        "color": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "asset": {
      "type": "object",
      "required": ["slug", "kind", "label"],
      "properties": {
        "slug": { "$ref": "#/$defs/slug" },
        "kind": { "enum": ["cover", "sprite", "background", "ambient", "sfx"] },
        "label": { "type": "string" },
        "file": { "type": "string", "description": "Path of the binary inside the archive's assets/ folder." },
        "thumbFile": { "type": "string" },
        "blurDataUrl": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "character": {
      "type": "object",
      "required": ["slug", "name"],
      "properties": {
        "slug": { "$ref": "#/$defs/slug" },
        "name": { "type": "string" },
        "description": { "type": "string", "description": "Prose. May contain inline reference tokens." },
        "coverAsset": { "type": "string" },
        "sprites": { "type": "array", "items": { "type": "string" } },
        "relatedRefs": { "type": "array", "items": { "$ref": "#/$defs/ref" } }
      }
    },
    "place": {
      "type": "object",
      "required": ["slug", "name"],
      "properties": {
        "slug": { "$ref": "#/$defs/slug" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "coverAsset": { "type": "string" },
        "backgrounds": { "type": "array", "items": { "type": "string" } },
        "ambientAudio": { "type": "array", "items": { "type": "string" } },
        "relatedRefs": { "type": "array", "items": { "$ref": "#/$defs/ref" } }
      }
    },
    "plotline": {
      "type": "object",
      "required": ["slug", "title"],
      "properties": {
        "slug": { "$ref": "#/$defs/slug" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "coverAsset": { "type": "string" },
        "color": { "type": "string" },
        "status": { "enum": ["planned", "active", "resolved"] },
        "members": {
          "type": "array",
          "description": "Ordered membership — story and event slugs in authored reading order.",
          "items": { "$ref": "#/$defs/ref" }
        }
      }
    },
    "event": {
      "type": "object",
      "required": ["slug", "name", "description", "inGameDate"],
      "properties": {
        "slug": { "$ref": "#/$defs/slug" },
        "name": { "type": "string" },
        "description": { "type": "string", "description": "Prose. May contain inline reference tokens." },
        "coverAsset": { "type": "string" },
        "bgmAsset": { "type": "string" },
        "backgroundEffect": { "enum": ["darken", "desaturate", "sepia", "cool", "warm"] },
        "inGameDate": { "$ref": "#/$defs/inGameDate" },
        "relatedRefs": { "type": "array", "items": { "$ref": "#/$defs/ref" } }
      }
    },
    "codexEntry": {
      "type": "object",
      "required": ["slug", "title", "description"],
      "properties": {
        "slug": { "$ref": "#/$defs/slug" },
        "title": { "type": "string" },
        "category": { "type": "string", "description": "The key of a codex category." },
        "description": { "type": "string", "description": "Prose. May contain inline reference tokens." },
        "coverAsset": { "type": "string" },
        "relatedRefs": { "type": "array", "items": { "$ref": "#/$defs/ref" } }
      }
    },
    "story": {
      "type": "object",
      "required": ["slug", "title", "inGameDate", "defaultEntryScene", "scenes"],
      "properties": {
        "slug": { "$ref": "#/$defs/slug" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "coverAsset": { "type": "string" },
        "bgmAsset": { "type": "string" },
        "draft": { "type": "boolean", "description": "Defaults to false. Set true to import the story unpublished." },
        "inGameDate": { "$ref": "#/$defs/inGameDate" },
        "relatedRefs": { "type": "array", "items": { "$ref": "#/$defs/ref" } },
        "defaultEntryScene": {
          "type": "string",
          "description": "The key of the scene readers start on by default. Make it a 'showcase' scene whose text is just the story title."
        },
        "scenes": {
          "type": "object",
          "description": "Map of scene key to scene. Keys are short author-chosen strings, local to this story. Keep each scene small — one beat.",
          "additionalProperties": { "$ref": "#/$defs/scene" }
        }
      }
    },
    "scene": {
      "type": "object",
      "required": ["text", "characters", "next"],
      "properties": {
        "text": {
          "type": "string",
          "description": "One beat of prose — a short paragraph or a character's full turn of speech. Don't split a single sentence across scenes, and don't pack several beats into one; a one-sentence scene is fine only when the moment is a deliberate beat. May contain inline reference tokens.",
          "minLength": 1
        },
        "label": { "type": "string", "description": "Optional short scene title." },
        "speaker": {
          "description": "The character speaking this line of dialogue. Set this only when the scene's text is spoken aloud by a character. Omit it for narration and description — never use a 'Narrator' label. A plain string is allowed only for a genuinely unnamed voice.",
          "oneOf": [{ "$ref": "#/$defs/ref" }, { "type": "string" }]
        },
        "backgroundAsset": { "type": "string" },
        "backgroundEffect": { "enum": ["darken", "desaturate", "sepia", "cool", "warm"] },
        "characters": {
          "type": "array",
          "description": "Characters staged on screen during this scene.",
          "items": { "$ref": "#/$defs/stagedCharacter" }
        },
        "place": { "$ref": "#/$defs/ref" },
        "sfxAsset": { "type": "string" },
        "bgmAsset": { "type": "string" },
        "bgmSilence": { "type": "boolean" },
        "bgmTransition": { "enum": ["crossfade", "cut"] },
        "textSpeed": { "enum": ["slow", "normal", "fast", "instant"] },
        "layout": {
          "enum": ["dialog", "showcase"],
          "description": "Omit for normal scenes. Use 'showcase' only for the opening title-card scene."
        },
        "transition": { "enum": ["crossfade", "fade-through-black"] },
        "transitionMs": { "type": "number" },
        "next": {
          "type": "array",
          "description": "Branches out of this scene. One entry is a linear continuation; several entries make a choice. An empty array is an ending.",
          "items": { "$ref": "#/$defs/sceneNext" }
        },
        "isEntry": {
          "type": "boolean",
          "description": "Marks an additional entry scene — connections from other stories or events may start the story here. The defaultEntryScene is always an entry."
        }
      }
    },
    "stagedCharacter": {
      "type": "object",
      "required": ["entity", "position"],
      "properties": {
        "entity": { "$ref": "#/$defs/ref" },
        "position": { "type": "string", "description": "Stage slot, e.g. left, center, right." },
        "order": { "type": "number" },
        "sprite": { "type": "string" },
        "facing": { "enum": ["left", "right"] }
      }
    },
    "sceneNext": {
      "type": "object",
      "required": ["scene"],
      "properties": {
        "label": { "type": "string", "description": "Choice text shown to the reader. Omit for a linear continuation." },
        "scene": { "type": "string", "description": "The key of the scene this branch leads to." }
      }
    },
    "connection": {
      "type": "object",
      "description": "A 'continues' edge. Both endpoints must be entities included in this same package — scene keys are local to the package.",
      "required": ["type", "from", "to", "visibility"],
      "properties": {
        "type": { "const": "continues" },
        "from": {
          "description": "The source ending: a story end scene (empty next) or an event. At most one connection per source.",
          "oneOf": [
            {
              "type": "object",
              "required": ["kind", "story", "scene"],
              "properties": {
                "kind": { "const": "story" },
                "story": { "$ref": "#/$defs/slug" },
                "scene": { "type": "string", "description": "Key of the source end scene." }
              }
            },
            {
              "type": "object",
              "required": ["kind", "event"],
              "properties": {
                "kind": { "const": "event" },
                "event": { "$ref": "#/$defs/slug" }
              }
            }
          ]
        },
        "to": {
          "description": "The target, or null for a pending hand-off (no target chosen yet). A story target may name an entry scene; omit 'scene' to use the story's defaultEntryScene.",
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "required": ["kind", "story"],
              "properties": {
                "kind": { "const": "story" },
                "story": { "$ref": "#/$defs/slug" },
                "scene": { "type": "string", "description": "Key of an entry scene (isEntry or the defaultEntryScene)." }
              }
            },
            {
              "type": "object",
              "required": ["kind", "event"],
              "properties": {
                "kind": { "const": "event" },
                "event": { "$ref": "#/$defs/slug" }
              }
            }
          ]
        },
        "visibility": {
          "enum": ["reader", "editor"],
          "description": "'reader' surfaces the continuation in the reader; 'editor' keeps it as an authoring note."
        },
        "note": { "type": "string", "description": "Optional author note — handy for pending hand-offs." },
        "snapshotTitle": { "type": "string", "description": "Cached target title, shown if the target later goes missing." }
      }
    }
  }
}
