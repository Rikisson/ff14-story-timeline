/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve",
    "baseUrl": "./",
    "paths": {
      "@features/auth": ["src/features/auth/index.ts"],
      "@features/universes": ["src/features/universes/index.ts"],
      "@features/universe-transfer": ["src/features/universe-transfer/index.ts"],
      "@features/stories": ["src/features/stories/index.ts"],
      "@features/characters": ["src/features/characters/index.ts"],
      "@features/places": ["src/features/places/index.ts"],
      "@features/events": ["src/features/events/index.ts"],
      "@features/plotlines": ["src/features/plotlines/index.ts"],
      "@features/codex": ["src/features/codex/index.ts"],
      "@features/calendar": ["src/features/calendar/index.ts"],
      "@features/media": ["src/features/media/index.ts"],
      "@features/timeline": ["src/features/timeline/index.ts"],
      "@features/reader": ["src/features/reader/index.ts"],
      "@features/editor": ["src/features/editor/index.ts"],
      "@shared/ui": ["src/shared/ui/index.ts"],
      "@shared/utils": ["src/shared/utils/index.ts"],
      "@shared/models": ["src/shared/models/index.ts"],
      "@shared/data-access": ["src/shared/data-access/index.ts"],
      "@shared/services": ["src/shared/services/index.ts"]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.spec.json"
    }
  ]
}
