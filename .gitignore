# See https://docs.github.com/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# Compiled output
/dist
/tmp
/out-tsc

# Node
/node_modules
npm-debug.log
yarn-error.log

# Environment
.env
.env.*

# IDEs and editors
.idea/
*.sublime-workspace

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json
.history/*

# Claude Code (local/personal files only)
.claude/settings.local.json
.claude/scheduled_tasks.lock
.superpowers

# Miscellaneous
/.angular/cache
.sass-cache/
/coverage
__screenshots__/

# Cloudflare Worker (cloudflare/*)
/cloudflare/*/node_modules
/cloudflare/*/.wrangler

# System files
.DS_Store
Thumbs.db
