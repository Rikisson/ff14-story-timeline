rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    match /stories/{storyId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && firestore.get(/databases/(default)/documents/stories/$(storyId)).data.authorUid
           == request.auth.uid;
    }
  }
}
