rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Mirrors firestore.rules#isMember — keep these in sync.
    function isMember(universeId) {
      let u = firestore.get(/databases/(default)/documents/universes/$(universeId)).data;
      return request.auth != null
        && (u.ownerUid == request.auth.uid || request.auth.uid in u.editorUids);
    }

    // All universe-scoped assets: scene backgrounds/audio, character portraits.
    // Path examples:
    //   universes/{u}/stories/{storyId}/scenes/{sceneId}/background/{file}
    //   universes/{u}/stories/{storyId}/scenes/{sceneId}/audio/{file}
    //   universes/{u}/characters/{characterId}/portraits/{portraitId}/{file}
    match /universes/{universeId}/{allPaths=**} {
      allow read: if true;
      allow write: if isMember(universeId)
        && request.resource.size < 25 * 1024 * 1024;
    }
  }
}
